#!/usr/bin/env bash

# shoutout https://mths.be/macos

# close any open System Preferences panes, to prevent them from overriding
# settings we’re about to change
osascript -e 'tell application "System Preferences" to quit'

# ask for the administrator password upfront
sudo -v

# keep-alive: update existing `sudo` time stamp until `.macos` has finished
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

# colors
defaults write -g AppleInterfaceStyle -string "Dark"
defaults write -g AppleIconAppearanceTheme -string "RegularDark"
defaults write -g AppleAccentColor -int 7 # almost mauve
defaults write -g AppleHighlightColor -string "0.796000 0.651000 0.969000" # mauve

defaults write -g AppleICUForce24HourTime -bool true

sudo pmset -c displaysleep 20 # sleep after X miutes when charging
sudo pmset -b displaysleep 10 # sleep after X miutes when on battery

# sensible defaults
defaults write -g NSUseAnimatedFocusRing -bool false # disable focus ring animation
defaults write com.apple.universalaccess reduceTransparency -bool true
defaults write com.apple.systempreferences NSQuitAlwaysKeepsWindows -bool false # don't remember app windows when closed
defaults write com.apple.LaunchServices LSQuarantine -bool false # allow all apps to be opened with out confirmation
sudo defaults write /Library/Preferences/com.apple.windowserver DisplayResolutionEnabled -bool true # enable HiDPI (requires restart)

# menu bar
defaults write -g _HIHideMenuBar -bool true # auto hide menu bar
defaults write -g AppleMenuBarVisibleInFullscreen -bool false

# spaces
defaults write com.apple.spaces spans-displays -bool true # enable displays have separate spaces
defaults write com.apple.dock mru-spaces -bool false # don't rearrange spaces

# dock
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock autohide-delay -float 100000 # make the dock never appear
defaults write com.apple.dock persistent-apps -array # clear default apps from dock
defaults write com.apple.dock show-recents -bool false
defaults write com.apple.dock no-bouncing -bool true

# disable hot corners
defaults write com.apple.dock wvous-tl-corner -int 0
defaults write com.apple.dock wvous-tl-modifier -int 0
defaults write com.apple.dock wvous-tr-corner -int 0
defaults write com.apple.dock wvous-tr-modifier -int 0
defaults write com.apple.dock wvous-bl-corner -int 0
defaults write com.apple.dock wvous-bl-modifier -int 0

defaults write -g ApplePressAndHoldEnabled -bool false # disable hold key for accents
defaults write -g KeyRepeat -int 2
defaults write -g InitialKeyRepeat -int 30

defaults write -g AppleEnableSwipeNavigateWithScrolls -bool false # disable swipe with scroll to navigate in web browsers
defaults write com.apple.AppleMultitouchTrackpad ActuateDetents -bool false # disable haptic feedback for force touch
defaults write com.apple.AppleMultitouchTrackpad ForceSuppressed -bool true # disable force touch (the hard click)
defaults write com.apple.dock showMissionControlGestureEnabled -bool false
defaults write com.apple.dock showAppExposeGestureEnabled -bool false
defaults write com.apple.dock showDesktopGestureEnabled -bool false

# turn off all other trackpad gestures
defaults write com.apple.AppleMultitouchTrackpad TrackpadFourFingerHorizSwipeGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerHorizSwipeGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadFourFingerVertSwipeGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerVertSwipeGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadFourFingerPinchGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadFiveFingerPinchGesture -bool false
defaults write com.apple.AppleMultitouchTrackpad TrackpadTwoFingerFromRightEdgeSwipeGesture -bool false # control panel
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadFourFingerHorizSwipeGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerHorizSwipeGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadFourFingerVertSwipeGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerVertSwipeGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadFourFingerPinchGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadFiveFingerPinchGesture -bool false
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadTwoFingerFromRightEdgeSwipeGesture -bool false # control panel

# typing
defaults write -g NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write com.apple.messageshelper.MessageController SOInputLineSettings -dict-add "automaticEmojiSubstitutionEnablediMessage" -bool false # no smart emojis
defaults write com.apple.messageshelper.MessageController SOInputLineSettings -dict-add "automaticQuoteSubstitutionEnabled" -bool false # no smart quotes

# disable all default keyboard shortcuts
for n in {10..260}; do
    /usr/libexec/PlistBuddy -c "set :AppleSymbolicHotKeys:$n:enabled 0" ~/Library/Preferences/com.apple.symbolichotkeys.plist > /dev/null 2>&1
done
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u

# finder
defaults write -g AppleShowAllExtensions -bool true
defaults write com.apple.finder DisableAllAnimations -bool true
defaults write com.apple.finder AppleShowAllFiles -bool true # show hidden files
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true # disable .DS_Store for network volumes
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true # disable .DS_Store for USB volumes
chflags nohidden ~/Library && xattr -d com.apple.FinderInfo ~/Library > /dev/null 2>&1 # show ~/Library
sudo chflags nohidden /Volumes # show /Volumes

# restart stuff
for app in "cfprefsd" \
    "Dock" \
    "Finder" \
    "Messages" \
    "SystemUIServer"; do
    killall "${app}" &> /dev/null
done

echo "Done. Note that some of these changes require a logout/restart to take effect."
